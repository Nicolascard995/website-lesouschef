# ============================================================
# Le Sous Chef — Variables de entorno
# Copiar a .env.local y completar los valores
# ============================================================

# Base de datos (Neon PostgreSQL)
DATABASE_URL=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=Le Sous Chef <hello@lesouschef.com>
RESEND_AUDIENCE_ID=

# Email de notificaciones internas
NOTIFY_EMAIL=
CONTACT_EMAIL=

# Pagos (Lemon Squeezy)
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Admin
ADMIN_TOKEN=
